# Sao chép file này thành .env (đã gitignore) rồi điền key thật — KHÔNG commit .env.

# ============ ASR (nhận giọng nói) ============
# QUYẾT ĐỊNH CHÍNH THỨC (spec §2): Google Cloud Speech-to-Text v2, model Chirp 3,
# là ASR chính (streaming + phrase hints từ danh mục thuốc; bake-off ở P2).
# Cần: GCP project đã bật Speech-to-Text API + service account JSON.
GOOGLE_APPLICATION_CREDENTIALS=
# ví dụ: GOOGLE_APPLICATION_CREDENTIALS=/home/vietlb/keys/vnai-gcp.json
GOOGLE_CLOUD_PROJECT=
# ví dụ: GOOGLE_CLOUD_PROJECT=vnai-hackathon
# (optional) region STT — chirp_3 + vi-VN hiện chỉ GA ở "eu" (default), xem app/backend/asr.py
GOOGLE_STT_LOCATION=

# STOPGAP TẠM cho nút mic demo khi CHƯA setup GCP: OpenAI whisper-1.
# Ưu tiên: có GOOGLE_APPLICATION_CREDENTIALS -> dùng Google; chỉ có OPENAI_API_KEY
# -> whisper tạm; thiếu cả hai -> /api/transcribe trả 503 tiếng Việt, frontend tự
# chuyển sang ô gõ chữ.
OPENAI_API_KEY=

# ============ P1: pipeline LLM ============
# Generator + Citations API (đường B canh tác): Claude
ANTHROPIC_API_KEY=
# Rewrite/router + judge runtime: Gemini Flash (judge offline dùng thêm GPT ở trên)
GEMINI_API_KEY=

# ============ P2: TTS giọng miền Nam (FPT.AI lannhi) ============
FPT_TTS_API_KEY=
