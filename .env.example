# Sao chép file này thành .env (đã gitignore) rồi điền key thật — KHÔNG commit .env.

# ============ ASR (nhận giọng nói) ============
# QUYẾT ĐỊNH CHÍNH THỨC (spec §2): Google Cloud Speech-to-Text v2, model Chirp 3,
# là ASR chính (streaming + phrase hints từ danh mục thuốc; bake-off ở P2).
# Cần: GCP project đã bật Speech-to-Text API + service account JSON.
GOOGLE_APPLICATION_CREDENTIALS=
# ví dụ: GOOGLE_APPLICATION_CREDENTIALS=/home/vietlb/keys/vnai-gcp.json
GOOGLE_CLOUD_PROJECT=
# ví dụ: GOOGLE_CLOUD_PROJECT=vnai-hackathon
# (optional) region STT — chirp_3 + vi-VN hiện chỉ GA ở "eu" (default), xem app/backend/asr.py
GOOGLE_STT_LOCATION=
# "auto" chỉ bỏ qua proxy loopback port 9 dùng để chặn mạng trong sandbox/local.
# Đặt true nếu Google STT cần đi thẳng; false nếu hạ tầng bắt buộc dùng proxy thật.
GOOGLE_STT_BYPASS_PROXY=auto

# ============ TTS fallback (đọc câu trả lời) ============
# Dùng cùng GOOGLE_APPLICATION_CREDENTIALS/GOOGLE_CLOUD_PROJECT ở trên; cần bật
# Cloud Text-to-Speech API. Chỉ gọi khi Web Speech API không có voice vi-VN.
GOOGLE_TTS_VOICE=vi-VN-Standard-A
# Google chấp nhận 0.25–4.0; 0.95 dễ nghe hơn cho câu tư vấn dài.
GOOGLE_TTS_SPEAKING_RATE=0.95

# STOPGAP TẠM cho nút mic demo khi CHƯA setup GCP: OpenAI whisper-1.
# Ưu tiên: có GOOGLE_APPLICATION_CREDENTIALS -> dùng Google; chỉ có OPENAI_API_KEY
# -> whisper tạm; thiếu cả hai -> /api/transcribe trả 503 tiếng Việt, frontend tự
# chuyển sang ô gõ chữ.
OPENAI_API_KEY=

# ============ P1: pipeline LLM ============
# Generator + Citations API (đường B canh tác): Claude
ANTHROPIC_API_KEY=
# Rewrite/router + judge runtime: Gemini Flash (judge offline dùng thêm GPT ở trên)
GEMINI_API_KEY=
# Duyệt input sai chính tả/phiên âm. "auto" = dùng Gemini khi có key; "off" =
# chỉ dùng candidate resolver deterministic (vẫn luôn hỏi xác nhận trước khi tra).
INPUT_REVIEW_MODE=auto
# Optional: override model nhẹ dùng riêng cho input review.
GEMINI_INPUT_REVIEW_MODEL=
# Agent truy vấn registry: Gemini chỉ chọn tên tool zero-argument; backend tự
# gắn product/crop/pest/date canonical và thực thi query có tham số.
REGISTRY_AGENT_MODE=auto
GEMINI_REGISTRY_AGENT_MODEL=

# ============ Khuyến nông: notify + dashboard ============
# --- Email báo cho bà con khi cán bộ trả lời (bỏ trống -> chỉ báo qua popup trong app) ---
# Dùng Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=địa chỉ Gmail,
# SMTP_PASS=App Password 16 ký tự (KHÔNG phải mật khẩu Gmail thường — tạo tại
# myaccount.google.com/apppasswords, cần bật 2FA trước). SMTP_FROM thường = SMTP_USER.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# ví dụ: SMTP_USER=bannhanong.demo@gmail.com
SMTP_PASS=
SMTP_FROM=
# --- Zalo OA: nhắn cho bà con qua Zalo (bỏ trống -> skip, log "zalo skipped") ---
# Cần Official Account đã duyệt: lấy access token tại developers.zalo.me
# (OA Management > chọn OA > Access Token). Token hết hạn phải refresh thủ công.
ZALO_OA_ACCESS_TOKEN=
# --- Dashboard cán bộ (/officer/) ---
# Đặt token thì mọi request /api/officer/* phải kèm header X-Officer-Token khớp
# (dashboard tự gắn nếu localStorage có key "officer_token"). Bỏ trống = mở tự do (demo).
OFFICER_TOKEN=
# Ngưỡng số câu hỏi cùng (vùng, bệnh) trong 7 ngày để bật alert vùng dịch trên dashboard.
ALERT_MIN_COUNT=3
# AI phân loại câu hỏi bệnh cho alert (Gemini flash-lite, 1 call/batch, backoff 5 phút
# khi lỗi). "auto" = bật khi có GEMINI_API_KEY; "off" = chỉ nhóm theo slot dịch hại cứng.
ALERT_AI_MODE=auto
# Optional: override model dùng riêng cho phân loại alert (mặc định gemini-flash-lite-latest).
GEMINI_ALERT_MODEL=

# ============ P2: TTS giọng miền Nam (FPT.AI lannhi) ============
FPT_TTS_API_KEY=
